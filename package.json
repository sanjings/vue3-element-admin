{
  "name": "vue-element-admin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "serve": "npm run dev",
    "start": "npm run dev",
    "build-only": "vite build",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "stylelint": "stylelint \"**/*.{html,vue,css,scss,sass,less}\" --fix",
    "prettier": "prettier \"**/*.{vue,js,cjs,jsx,ts,tsx,json,css,less,scss,sass,html,md}\" --write",
    "format": "npm run prettier && npm run stylelint",
    "type-check": "vue-tsc --noEmit",
    "prepare": "husky",
    "ytt": "npx ytt"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,cjs,json,md,vue,html,scss,sass,css,less}": [
      "prettier --write"
    ],
    "*.{vue,html,scss,css,less,sass}": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "@amap/amap-jsapi-loader": "1.0.1",
    "@element-plus/icons-vue": "2.3.2",
    "@videojs-player/vue": "1.0.0",
    "axios": "1.13.6",
    "crypto-js": "4.2.0",
    "dayjs": "1.11.20",
    "element-plus": "^2.13.5",
    "js-base64": "3.7.8",
    "nprogress": "0.2.0",
    "path-browserify": "1.0.1",
    "pinia": "3.0.4",
    "pinia-plugin-persistedstate": "4.7.1",
    "v-viewer": "3.0.23",
    "video.js": "8.23.7",
    "viewerjs": "1.11.7",
    "vue": "^3.5.30",
    "vue-router": "5.0.3"
  },
  "devDependencies": {
    "@amap/amap-jsapi-types": "0.0.15",
    "@commitlint/config-conventional": "20.5.0",
    "@types/crypto-js": "4.2.2",
    "@types/node": "^25.5.0",
    "@types/nprogress": "0.2.3",
    "@types/path-browserify": "1.0.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "commitlint": "20.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "postcss-html": "1.8.1",
    "postcss-scss": "4.0.9",
    "prettier": "3.8.1",
    "sass-embedded": "^1.98.0",
    "sharp": "0.34.5",
    "stylelint": "17.4.0",
    "stylelint-config-recess-order": "7.6.1",
    "stylelint-config-recommended-scss": "17.0.0",
    "stylelint-config-recommended-vue": "1.6.1",
    "stylelint-prettier": "5.0.3",
    "svgo": "4.0.1",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "8.0.0",
    "vite-plugin-compression": "0.5.1",
    "vite-plugin-image-optimizer": "2.0.3",
    "vue-tsc": "^3.2.5",
    "yapi-to-typescript": "3.38.0"
  },
  "resolutions": {
    "vite": "8.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=20.0.0"
  }
}
