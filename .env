# 所有环境自定义的环境变量（命名必须以 VITE_ 开头）

## 项目标题
VITE_APP_TITLE = vue-element-admin

## 环境地址前缀（一般 '/'，'./' 都可以）
VITE_PUBLIC_PATH = './'

## http接口请求baseUrl
VITE_HTTP_BASE_URL = '/api'

## 本地缓存版本
VITE_CACHE_VERSION = v20260311

## AES密钥
VITE_CRYPTO_SECRET = 'k9B2s#7P$xQ!zR8a@3Fm*5Gv&2Dq+9Lw'

## AES 16位偏移量
VITE_CRYPTO_IV = 'X7s9#2P$!zR8a@3F'
